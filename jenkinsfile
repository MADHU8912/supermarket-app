pipeline {
    agent any

    environment {
        IMAGE = "yourdockerhub/supermarket-app"
    }

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/YOUR_USERNAME/supermarket-app.git'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t %IMAGE%:v1 backend'
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat 'echo %PASS% | docker login -u %USER% --password-stdin'
                }
            }
        }

        stage('Push Image') {
            steps {
                bat 'docker push %IMAGE%:v1'
            }
        }
    }
}